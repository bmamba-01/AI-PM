{
  "name": "@ai-pm/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "start": "pnpm build && electron .",
    "electron:dev": "pnpm build && cross-env NODE_ENV=production electron .",
    "electron:smoke": "pnpm build && cross-env NODE_ENV=production AI_PM_DESKTOP_SMOKE=1 electron .",
    "electron:build": "electron-builder",
    "clean": "rm -rf dist build"
  },
  "dependencies": {
    "@ai-pm/agents": "workspace:*",
    "@ai-pm/core": "workspace:*",
    "@ai-pm/mcp": "workspace:*",
    "@ai-pm/server": "workspace:*",
    "@ai-pm/shared": "workspace:*",
    "@tanstack/react-query": "^5.40.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.400.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.2.0",
    "vitest": "^2.0.0"
  }
}
