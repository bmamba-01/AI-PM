{
  "name": "@ai-pm/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "ai-pm": "./dist/bin/ai-pm.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-pm/core": "workspace:*",
    "@ai-pm/agents": "workspace:*",
    "@ai-pm/mcp": "workspace:*",
    "@ai-pm/shared": "workspace:*",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "inquirer": "^9.2.0",
    "table": "^6.8.0",
    "conf": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/inquirer": "^9.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}