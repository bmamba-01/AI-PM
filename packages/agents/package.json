{
  "name": "@ai-pm/agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "/registry": {
      "import": "./dist/registry/index.js",
      "types": "./dist/registry/index.d.ts"
    },
    "/orchestrator": {
      "import": "./dist/orchestrator/index.js",
      "types": "./dist/orchestrator/index.d.ts"
    },
    "/pm-agents": {
      "import": "./dist/pm-agents/index.js",
      "types": "./dist/pm-agents/index.d.ts"
    },
    "/role-agents": {
      "import": "./dist/role-agents/index.js",
      "types": "./dist/role-agents/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-pm/core": "workspace:*",
    "@ai-pm/mcp": "workspace:*",
    "@ai-pm/shared": "workspace:*",
    "zod": "^3.23.0",
    "uuid": "^10.0.0",
    "eventemitter3": "^5.0.0",
    "p-limit": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}