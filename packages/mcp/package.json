{
  "name": "@ai-pm/mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./registry": {
      "import": "./dist/registry/index.js",
      "types": "./dist/registry/index.d.ts"
    },
    "./wrappers": {
      "import": "./dist/wrappers/index.js",
      "types": "./dist/wrappers/index.d.ts"
    },
    "./registry/configLoader": {
      "import": "./dist/registry/configLoader.js",
      "types": "./dist/registry/configLoader.d.ts"
    },
    "./registry/configValidator": {
      "import": "./dist/registry/configValidator.js",
      "types": "./dist/registry/configValidator.d.ts"
    },
    "./connectionManager": {
      "import": "./dist/connectionManager.js",
      "types": "./dist/connectionManager.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-pm/core": "workspace:*",
    "@ai-pm/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "yaml": "^2.9.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "yaml": "^2.9.0"
  }
}
