# === AI-PM Monorepo .gitignore ===

# Dependencies
node_modules/
.pnpm-store/
.pnpm-debug.log

# Build outputs
dist/
build/
output/
*.tsbuildinfo
*.tsbuildinfo.map

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment & secrets
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log
logs/
npm-debug.log*
pnpm-debug.log*

# Test & coverage
coverage/
*.lcov
.nyc_output/

# Cache
.cache/
.parcel-cache/
.svelte-kit/
.vitepress/dist/
.vitepress/cache/

# TypeScript
*.tsbuildinfo

# AI-PM local data (user-specific, don't commit)
.ai-pm/
*.db
*.sqlite
*.sqlite3

# Mobile builds
packages/mobile/android/
packages/mobile/ios/
*.apk
*.ipa
*.aab

# Electron builds
packages/desktop/dist/
packages/desktop/release/
packages/desktop/build/
*.dmg
*.exe
*.AppImage
*.deb
*.rpm

# MCP local config
packages/mcp/config.local.json

# Temp files
_tmp_*

# Misc
*.tgz
*.tar.gz
*.zip
.temp/
.tmp/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# pnpm
.pnpm-store

# yarn v3
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Vite files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.vite/
