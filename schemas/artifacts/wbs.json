{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-pm-toolkit.dev/schemas/artifacts/wbs.json",
  "title": "Work Breakdown Structure",
  "description": "CSV-compatible table schema for WBS data",
  "type": "object",
  "properties": {
    "columns": {
      "type": "array",
      "description": "Column definitions for the WBS table",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["string", "number", "date", "enum", "boolean"] },
          "description": { "type": "string" },
          "required": { "type": "boolean", "default": false },
          "enum_values": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "required_columns": { "type": "array", "items": { "type": "string" } }
  },
  "required": ["columns", "required_columns"]
}
